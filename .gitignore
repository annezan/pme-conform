# -----------------------------------------------------------------------
# PME-CONFORM — .gitignore monorepo
# -----------------------------------------------------------------------

# ==== Backend Laravel ==================================================
backend/vendor/
backend/node_modules/

# Environnements (secrets — a definir manuellement sur chaque instance)
backend/.env
backend/.env.backup
backend/.env.production
!backend/.env.example

# Storage — donnees runtime, jamais versionnees
backend/storage/*.key
backend/storage/app/*
!backend/storage/app/.gitignore
!backend/storage/app/public/
backend/storage/app/public/*
!backend/storage/app/public/.gitignore
backend/storage/framework/cache/*
!backend/storage/framework/cache/.gitignore
backend/storage/framework/sessions/*
!backend/storage/framework/sessions/.gitignore
backend/storage/framework/views/*
!backend/storage/framework/views/.gitignore
backend/storage/logs/*
!backend/storage/logs/.gitignore
backend/storage/framework/dump.txt
backend/storage/workers-logs/
backend/storage/debugbar/

# Bootstrap cache (regenere par Laravel)
backend/bootstrap/cache/*.php
!backend/bootstrap/cache/.gitignore

# Symlinks generes
backend/public/storage
backend/public/hot
backend/public/build/

# Fichiers PhpUnit / Cover
backend/coverage/
backend/.phpunit.cache/
backend/.phpunit.result.cache

# Scripts one-shot de debug/repair (ne pas versionner)
backend/fix_*.php
backend/verif_*.php
backend/check_*.php
backend/check-*.php
backend/test_*.php
backend/explore_*.php
backend/backfill_*.php
backend/retry_*.php
backend/monitor.php
backend/gen_cahier_*.php
backend/read_doc.php
backend/preview_titles.php
backend/count_templates.php
backend/analyse_4_result.php
backend/rename_manage_perms.ps1
backend/revert_items_perm.ps1
backend/debug-*.ps1
backend/test-*.ps1
backend/test-api.sh

# ==== Frontend React / Vite ============================================
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.vite/

# Environnements front
frontend/.env
frontend/.env.local
frontend/.env.production.local
frontend/.env.development.local
!frontend/.env.example
# .env.production ne contient que des URLs publiques (VITE_*) : versionne
!frontend/.env.production

# ==== IDE / Editeurs ===================================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# ==== Outillage local ==================================================
.git.backup/
.claude/

# ==== OS ==============================================================
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/
ehthumbs.db

# ==== Documents temporaires / generes ==================================
*.docx.tmp
~$*.docx
~$*.xlsx
~$*.pptx

# Cahier des charges genere : versionne pour la reference
!Cahier-des-Charges-PME-CONFORM.docx
!Fiche-Configuration-Serveur-PME-CONFORM.docx

# ==== Archives / sauvegardes locales (ne JAMAIS versionner) ============
# Trop lourdes pour Git, souvent des snapshots de zip/rar de securite locale.
*.rar
*.zip
*.7z
*.tar
*.tar.gz
*.tgz

# ==== Divers ==========================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
